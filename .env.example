# ─── PharosWatch Configuration ───────────────────────────────────────────────

# Discord webhook URL (required for alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ─── Pharos Network (update once API is live) ─────────────────────────────────
PHAROS_WS_URL=wss://placeholder.pharos.network/ws
PHAROS_RPC_URL=https://placeholder.pharos.network/rpc

# ─── Tracking ─────────────────────────────────────────────────────────────────
# Comma-separated wallet addresses to watch
TRACKED_WALLETS=0xYourWallet1,0xYourWallet2

# Comma-separated contract addresses to watch
TRACKED_CONTRACTS=0xContract1,0xContract2

# Minimum transfer value to trigger an alert (in ETH)
MIN_TRANSFER_VALUE_ETH=0.01

# ─── Mode ─────────────────────────────────────────────────────────────────────
# Set to false when Pharos API is live
SIMULATION_MODE=true

# Seconds between simulated events
POLL_INTERVAL=5
